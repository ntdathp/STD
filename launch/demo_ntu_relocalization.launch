<launch>
<!-- Launch file for Livox AVIA LiDAR -->

  <arg name="rviz" default="true" />
  <rosparam command="load" file="$(find std_detector)/config/config_ntu.yaml" />
  <node  pkg="std_detector" type="relocalization_ntu" name="relocalization_ntu" output="screen"/>

  <!-- Pose gt -->
  <param name="reference_gt_path"            type="string" value = ""/>

  <param name="localization_lidar_path"      type="string" value = "/home/dat/data/MCDVIRAL/NTU/exp/ntu_day_01/out_pcd_deskew_xyzi/"/>
  <param name="localization_pose_path"       type="string" value = "/home/dat/data/MCDVIRAL/NTU/exp/ntu_day_01/traj_deskew_ref.csv"/>
  
  <param name="generate_descriptor_database" type="bool"   value = "true"/>
  
  <param name="generated_lidar_path"         type="string" value = "/home/dat/data/kitti/enu_frames_00_global00/pcd/"/>
  <param name="generated_pose_path"          type="string" value = "/home/dat/data/kitti/enu_frames_00_global00/traj_imu_ENU_global00_00.csv"/>
  <param name="descriptor_file_path"         type="string" value = "/home/dat/data/std_reloc/kitti/saved_descriptors_00/"/>

  <!-- <group if="$(arg rviz)">
    <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find std_detector)/rviz_cfg/demo.rviz" />
  </group> -->

</launch>